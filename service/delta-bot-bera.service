[Unit]
Description=Delta Exchange Trading Bot - BERAUSD Donchian Channel (1H Heikin Ashi)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/delta-exchange-alog/logs
# Runs strategy ID 12: BERAUSD Donchian Channel, 1H Heikin Ashi, 5x leverage, $50 target margin
ExecStart=/home/pi/delta-exchange-alog/logs/venv/bin/python3 -u /home/pi/delta-exchange-alog/logs/run_terminal.py --strategy 12 --non-interactive
Restart=on-failure
RestartSec=60
EnvironmentFile=/home/pi/delta-exchange-alog/logs/config/.env

# Logging — stdout goes to bera.log, stderr (crashes/tracebacks) to bera.error.log
StandardOutput=append:/home/pi/delta-exchange-alog/logs/logs/bera.log
StandardError=append:/home/pi/delta-exchange-alog/logs/logs/bera.error.log

[Install]
WantedBy=multi-user.target
