[Unit]
Description=Delta Exchange Trading Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/delta-exchange-alog/logs
ExecStart=/home/pi/delta-exchange-alog/logs/venv/bin/python3 -u /home/pi/delta-exchange-alog/logs/run_terminal.py --strategy 9 --non-interactive
Restart=on-failure
RestartSec=60
EnvironmentFile=/home/pi/delta-exchange-alog/logs/config/.env

# Logging
StandardOutput=append:/home/pi/delta-exchange-alog/logs/logs/xrp.log
StandardError=append:/home/pi/delta-exchange-alog/logs/logs/xrp.error.log

[Install]
WantedBy=multi-user.target
