//@version=5
strategy("BB Breakout + EMA + Squeeze + Volume + Risk", 
     overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10)

// ===== INPUTS ===== //

// Bollinger Bands
bbLength = input.int(20, "BB Length")
bbMult = input.float(2.0, "BB Multiplier")
src = input.source(close, "Source")

// EMA Trend Filter
useEMA = input.bool(true, "Use EMA Filter")
emaLength = input.int(200, "EMA Length")

// Trade Mode
tradeMode = input.string("BOTH", "Trade Mode", options=["LONG", "SHORT", "BOTH"])

// ATR Trailing Stop Loss
useSL     = input.bool(true,  "Use Trailing Stop Loss")
atrLength = input.int(14,     "ATR Length")
atrMult   = input.float(2.0,  "ATR Multiplier")

// Squeeze Filter (TTM Squeeze: BB inside Keltner Channels)
useSqueeze    = input.bool(true, "Use Squeeze Filter")
kcMult        = input.float(1.5, "KC Multiplier", minval=0.1, step=0.1, tooltip="Keltner Channel multiplier. Standard TTM Squeeze uses 1.5")
squeezeWindow = input.int(5, "Squeeze Window (bars)", minval=1, maxval=20, tooltip="Allow entry within N bars after squeeze fires. Squeeze releases first, BB breakout follows a few bars later.")

// Volume Filter
useVolume = input.bool(true, "Use Volume Filter")
volLength = input.int(20, "Volume MA Length")
volMultiplier = input.float(1.5, "Volume Multiplier")

// ===== CALCULATIONS ===== //

// Bollinger Bands
basis = ta.sma(src, bbLength)
dev = bbMult * ta.stdev(src, bbLength)
upper = basis + dev
lower = basis - dev

// ATR (must be defined before Keltner Channels)
atr = ta.atr(atrLength)

// TTM Squeeze: Squeeze is ON when BB is fully inside Keltner Channels
kcUpper = basis + kcMult * atr
kcLower = basis - kcMult * atr
// Squeeze ON  → BB completely inside KC (low volatility, coiling)
isSqueeze    = upper < kcUpper and lower > kcLower
wasInSqueeze = upper[1] < kcUpper[1] and lower[1] > kcLower[1]
// Squeeze Release: BB breaks outside KC on this exact bar
squeezeRelease = wasInSqueeze and not isSqueeze
// Recent Release: squeeze fired within the last N bars (breakout usually follows a few bars after)
recentRelease = ta.barssince(squeezeRelease) <= squeezeWindow

// EMA
ema = ta.ema(close, emaLength)

// Volume
volMA = ta.sma(volume, volLength)
highVolume = volume > volMA * volMultiplier

// ===== ENTRY CONDITIONS ===== //

// Breakouts
longBreakout = ta.crossover(close, upper)
shortBreakout = ta.crossunder(close, lower)

// Apply filters
longEntry = longBreakout and
             (not useEMA or close > ema) and
             (not useSqueeze or recentRelease) and
             (not useVolume or highVolume)
shortEntry = shortBreakout and
             (not useEMA or close < ema) and
             (not useSqueeze or recentRelease) and
             (not useVolume or highVolume)

// ===== EXIT CONDITIONS ===== //

longExit = ta.crossunder(close, basis)
shortExit = ta.crossover(close, basis)

// Prevent trading if equity <= 0
canTrade = strategy.equity > 0

// ===== EXECUTION ===== //

// LONG
if canTrade and (tradeMode == "LONG" or tradeMode == "BOTH")
    if longEntry
        strategy.entry("Long", strategy.long)
    if longExit
        strategy.close("Long")

// SHORT
if canTrade and (tradeMode == "SHORT" or tradeMode == "BOTH")
    if shortEntry
        strategy.entry("Short", strategy.short)
    if shortExit
        strategy.close("Short")

// ===== TRAILING STOP LOSS ===== //

var float trailLongSL  = na
var float trailShortSL = na

if strategy.position_size > 0
    // Ratchet SL upward as price rises — never pulls back down
    trailLongSL  := math.max(nz(trailLongSL, low), close - atr * atrMult)
else if strategy.position_size < 0
    // Ratchet SL downward as price falls — never pulls back up
    trailShortSL := math.min(nz(trailShortSL, high), close + atr * atrMult)
else
    trailLongSL  := na
    trailShortSL := na

if useSL
    strategy.exit("Long TSL",  from_entry="Long",  stop=trailLongSL)
    strategy.exit("Short TSL", from_entry="Short", stop=trailShortSL)

// ===== VISUALS ===== //

plot(basis, color=color.blue,   title="BB Basis")
plot(upper, color=color.red,    title="BB Upper")
plot(lower, color=color.green,  title="BB Lower")
plot(ema,   color=color.orange, title="EMA")

// Trailing SL — orange line, only visible while in a trade
activeTSL = strategy.position_size > 0 ? trailLongSL : strategy.position_size < 0 ? trailShortSL : na
plot(activeTSL, title="Trailing SL", color=color.new(color.orange, 0), style=plot.style_linebr, linewidth=2)

// Background: position takes priority over squeeze highlight
inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0
bg = inLong ? color.new(color.green, 85) : inShort ? color.new(color.red, 85) : isSqueeze ? color.new(color.yellow, 85) : na
bgcolor(bg)

// ===== ALERTS ===== //

alertcondition(longEntry, title="Long Entry", message="BB Breakout Long + Volume")
alertcondition(shortEntry, title="Short Entry", message="BB Breakout Short + Volume")

alertcondition(longExit, title="Long Exit", message="Exit Long")
alertcondition(shortExit, title="Short Exit", message="Exit Short")