//@version=5
strategy("BB Breakout + EMA + Squeeze + Volume + Risk", 
     overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10)

// ===== INPUTS ===== //

// Bollinger Bands
bbLength = input.int(20, "BB Length")
bbMult = input.float(2.0, "BB Multiplier")
src = input.source(close, "Source")

// EMA Trend Filter
useEMA = input.bool(true, "Use EMA Filter")
emaLength = input.int(200, "EMA Length")

// Trade Mode
tradeMode = input.string("BOTH", "Trade Mode", options=["LONG", "SHORT", "BOTH"])

// ATR Stop Loss
useSL = input.bool(true, "Use ATR Stop Loss")
atrLength = input.int(14, "ATR Length")
atrMult = input.float(2.0, "ATR Multiplier")

// Squeeze Filter
useSqueeze = input.bool(true, "Use Squeeze Filter")
squeezeThreshold = input.float(0.05, "BB Width Threshold")

// Volume Filter
useVolume = input.bool(true, "Use Volume Filter")
volLength = input.int(20, "Volume MA Length")
volMultiplier = input.float(1.5, "Volume Multiplier")

// ===== CALCULATIONS ===== //

// Bollinger Bands
basis = ta.sma(src, bbLength)
dev = bbMult * ta.stdev(src, bbLength)
upper = basis + dev
lower = basis - dev

// BB Width
bbWidth = (upper - lower) / basis
isSqueeze = bbWidth < squeezeThreshold

// EMA
ema = ta.ema(close, emaLength)

// ATR
atr = ta.atr(atrLength)

// Volume
volMA = ta.sma(volume, volLength)
highVolume = volume > volMA * volMultiplier

// ===== ENTRY CONDITIONS ===== //

// Breakouts
longBreakout = ta.crossover(close, upper)
shortBreakout = ta.crossunder(close, lower)

// Apply filters
longEntry = longBreakout and (not useEMA or close > ema) and (not useSqueeze or isSqueeze) and (not useVolume or highVolume)
shortEntry = shortBreakout and 
             (not useEMA or close < ema) and 
             (not useSqueeze or isSqueeze) and 
             (not useVolume or highVolume)

// ===== EXIT CONDITIONS ===== //

longExit = ta.crossunder(close, basis)
shortExit = ta.crossover(close, basis)

// Prevent trading if equity <= 0
canTrade = strategy.equity > 0

// ===== EXECUTION ===== //

// LONG
if canTrade and (tradeMode == "LONG" or tradeMode == "BOTH")
    if longEntry
        strategy.entry("Long", strategy.long)
    if longExit
        strategy.close("Long")

// SHORT
if canTrade and (tradeMode == "SHORT" or tradeMode == "BOTH")
    if shortEntry
        strategy.entry("Short", strategy.short)
    if shortExit
        strategy.close("Short")

// ===== STOP LOSS ===== //

if useSL
    longSL = strategy.position_avg_price - atr * atrMult
    shortSL = strategy.position_avg_price + atr * atrMult

    strategy.exit("Long SL", from_entry="Long", stop=longSL)
    strategy.exit("Short SL", from_entry="Short", stop=shortSL)

// ===== VISUALS ===== //

plot(basis, color=color.blue)
plot(upper, color=color.red)
plot(lower, color=color.green)
plot(ema, color=color.orange)

// Squeeze highlight
bgcolor(isSqueeze ? color.new(color.yellow, 85) : na)

// Position background
inLong = strategy.position_size > 0
inShort = strategy.position_size < 0

bgcolor(inLong ? color.new(color.green, 85) : na)
bgcolor(inShort ? color.new(color.red, 85) : na)

// ===== ALERTS ===== //

alertcondition(longEntry, title="Long Entry", message="BB Breakout Long + Volume")
alertcondition(shortEntry, title="Short Entry", message="BB Breakout Short + Volume")

alertcondition(longExit, title="Long Exit", message="Exit Long")
alertcondition(shortExit, title="Short Exit", message="Exit Short")